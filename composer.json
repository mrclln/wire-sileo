{
    "name": "mrclln/wire-sileo",
    "description": "A Laravel Livewire package for Sileo notifications with a fluent API and facade support.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "livewire",
        "sileo",
        "notification",
        "toast",
        "alert"
    ],
    "authors": [
        {
            "name": "mrclln",
            "email": "mojicamarcallen@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "livewire/livewire": "^3.0|^4.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "mrclln\\WireSileo\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "mrclln\\WireSileo\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "mrclln\\WireSileo\\WireSileoServiceProvider"
            ],
            "aliases": {
                "WireSileo": "mrclln\\WireSileo\\Facades\\WireSileo"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
