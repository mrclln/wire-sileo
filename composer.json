{
    "name": "mrclln/wire-sileo",
    "description": "A Laravel Livewire package for the Sileo React component",
    "keywords": [
        "laravel",
        "livewire",
        "sileo",
        "notification",
        "toast"
    ],
    "homepage": "https://github.com/mrclln/wire-sileo",
    "license": "MIT",
    "authors": [
        {
            "name": "mrclln",
            "email": "mojicamarcallen@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "livewire/livewire": "^3.0|^4.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.70",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.5|^10.0|^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "Sileo\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sileo\\Tests\\": "tests"
        }
    },
    "scripts": {
        "ci": [
            "@composer csfixer",
            "@composer phpstan",
            "@composer test"
        ],
        "csfixer": "PHP_CS_FIXER_IGNORE_ENV=1 ./vendor/bin/php-cs-fixer fix src",
        "phpstan": "./vendor/bin/phpstan analyse src tests --level=7",
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sileo\\SileoServiceProvider"
            ],
            "aliases": {
                "Sileo": "Sileo\\Facades\\Sileo"
            }
        }
    }
}
